# Template de variáveis de ambiente do Agente B3
# Copie este arquivo para .env e preencha os valores

# Credencial B3 RJLF (para uso futuro)
B3_RJLF_USER=
B3_RJLF_PASSWORD=
B3_RJLF_TOKEN=

# Proxy HTTP (opcional)
# HTTP_PROXY=http://usuario:senha@proxy:porta
# HTTPS_PROXY=http://usuario:senha@proxy:porta

# Diretório de saída customizado (opcional — padrão: outputs/)
# OUTPUT_DIR=C:\Relatorios\LFs

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
